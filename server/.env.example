# Server Configuration
SERVER_HOST=localhost
SERVER_PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/perplexity-clone

# JWT
JWT_SECRET=your_jwt_secret_key_here

# Google OAuth (Optional)
GOOGLE_OAUTH_CLIENTID=your_google_client_id
GOOGLE_OAUTH_SECRETKEY=your_google_client_secret
GOOGLE_OAUTH_CALLBACK=http://localhost:5000/api/auth/google/callback

# Client URL
CLIENT_URL=http://localhost:5173

# AI/LLM Configuration
MISTRALAI_API_KEY=your_mistral_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=perplexity

# File Upload
MAX_FILE_SIZE=52428800
UPLOAD_DIR=uploads
